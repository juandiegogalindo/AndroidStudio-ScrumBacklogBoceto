<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <Button
        android:id="@+id/btnConsulta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Consulta Precio"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnInventario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Manejo Inventario"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnSalidas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Manejo Salidas"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnNotificador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Alertas Inventario"
        android:layout_marginBottom="16dp"/>

</LinearLayout>