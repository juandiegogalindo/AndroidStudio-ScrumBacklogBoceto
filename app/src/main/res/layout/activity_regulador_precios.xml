<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Regulador de Precios"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <!-- CIUDAD -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ciudad"/>

    <Spinner
        android:id="@+id/spCiudad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <!-- ZONA -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Zona"/>

    <Spinner
        android:id="@+id/spZona"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <!-- COMBUSTIBLE -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tipo de Combustible"/>

    <Spinner
        android:id="@+id/spCombustible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"/>

    <!-- PRECIO ACTUAL -->

    <TextView
        android:id="@+id/txtPrecioActual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Precio actual: $0"
        android:textSize="18sp"
        android:layout_marginBottom="20dp"/>

    <!-- NUEVO PRECIO -->

    <EditText
        android:id="@+id/etNuevoPrecio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nuevo precio"
        android:inputType="numberDecimal"
        android:layout_marginBottom="20dp"/>

    <!-- BOTONES -->

    <Button
        android:id="@+id/btnActualizarPrecio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Actualizar Precio"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnVolver"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Volver"/>

</LinearLayout>